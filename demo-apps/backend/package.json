{
  "name": "demo-apps-backend",
  "version": "vv3.4.0-beta.0",
  "private": true,
  "homepage": "https://gqlts.vercel.app",
  "license": "MIT",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build-sdk": "cd sdk && yarn && yarn build-sdk",
    "dev": "PORT=${PORT:-4000} ts-node src/index.ts",
    "start": "PORT=${PORT:-4000} node dist/index.js",
    "test": "NODE_ENV=test jest -c ./__tests__/jest.config.js --runInBand --forceExit",
    "typecheck": "tsc --pretty --skipLibCheck --noEmit"
  },
  "dependencies": {
    "@envelop/parser-cache": "10.1.1",
    "@envelop/validation-cache": "10.1.1",
    "@graphql-tools/schema": "10.0.32",
    "graphql": "16.13.2",
    "graphql-scalars": "1.25.0",
    "graphql-upload-ts": "2.1.3",
    "graphql-yoga": "5.21.0",
    "nexus": "1.3.0",
    "supertest": "7.2.2",
    "ts-node": "10.9.2",
    "typescript": "6.0.3"
  },
  "devDependencies": {
    "@gqlts/runtime": "file:../../runtime",
    "@types/jest": "30.0.0",
    "@types/supertest": "7.2.0",
    "jest": "30.3.0",
    "ts-jest": "29.4.9"
  }
}
