{
  "name": "demo-apps-backend",
  "version": "3.2.21",
  "private": true,
  "homepage": "https://gqlts.vercel.app",
  "license": "MIT",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build-sdk": "cd sdk && yarn && yarn build-sdk",
    "dev": "PORT=${PORT:-4000} ts-node src/index.ts",
    "start": "PORT=${PORT:-4000} node dist/index.js",
    "test": "NODE_ENV=test jest -c ./__tests__/jest.config.js --runInBand --forceExit",
    "typecheck": "tsc --pretty --skipLibCheck --noEmit"
  },
  "dependencies": {
    "@envelop/parser-cache": "10.1.0",
    "@envelop/validation-cache": "10.1.0",
    "@graphql-tools/schema": "10.0.31",
    "graphql": "16.12.0",
    "graphql-scalars": "1.25.0",
    "graphql-upload-ts": "2.1.3",
    "graphql-yoga": "5.18.0",
    "nexus": "1.3.0",
    "supertest": "7.2.2",
    "ts-node": "10.9.2",
    "typescript": "5.9.3",
    "uuid": "13.0.0"
  },
  "devDependencies": {
    "@types/jest": "30.0.0",
    "@types/supertest": "6.0.3",
    "jest": "30.2.0",
    "ts-jest": "29.4.6"
  }
}
