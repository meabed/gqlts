{
  "name": "gqlts",
  "version": "3.4.0",
  "private": true,
  "keywords": [
    "gqlts",
    "graphql",
    "axios",
    "typescript",
    "types-graphql",
    "types-graphql-client",
    "types-graphql-axios",
    "graphql-sdk",
    "graphql-sdk-generator",
    "graphql-sdk-cli",
    "graphql-subscriptions",
    "graphql-subscriptions-client",
    "graphql-typescript",
    "graphql-axios-client",
    "graphql-typescript-client",
    "graphql-typescript-sdk"
  ],
  "homepage": "https://gqlts.vercel.app",
  "repository": "github:meabed/gqlts",
  "license": "MIT",
  "author": {
    "name": "Mohamed Meabed",
    "email": "mo@meabed.com",
    "url": "https://meabed.com"
  },
  "maintainers": [
    {
      "name": "Mohamed Meabed",
      "email": "mo@meabed.com",
      "url": "https://meabed.com"
    }
  ],
  "workspaces": [
    "cli",
    "runtime"
  ],
  "scripts": {
    "buildall": "ultra -r --filter '@gqlts/*' --topology build",
    "changeset": "changeset",
    "genall": "ultra -r gen",
    "prettier": "prettier --write \"cli/**/*.{ts,tsx,js,jsx}\" \"runtime/**/*.{ts,tsx,js,jsx}\" \"demo-apps/**/*.{ts,tsx,js,jsx}\"",
    "release:check": "node ./scripts/release/check-changeset.mjs",
    "release:publish": "node ./scripts/release/publish.mjs",
    "release:verify": "yarn buildall && yarn test && ./demo-apps/build-and-test.sh",
    "release:version:beta": "node ./scripts/release/version-beta.mjs",
    "release:version:stable": "node ./scripts/release/version-stable.mjs",
    "test": "ultra -r test",
    "tscall": "ultra -r --filter '@gqlts/*' tsc",
    "watch": "ultra -r watch"
  },
  "resolutions": {
    "graphql": "16.13.2",
    "ws": "8.20.0"
  },
  "devDependencies": {
    "@changesets/cli": "2.29.7",
    "@ianvs/prettier-plugin-sort-imports": "4.7.1",
    "prettier": "3.8.3",
    "typescript": "6.0.3",
    "ultra-runner": "3.10.5"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
